# Optional local overrides — copy to .env when needed (git-ignored, never commit).
# If .env is absent: npm scripts / Gradle still work; use shell env or built-in defaults.
# Template only — do not rely on .env.example values in production builds.

# --- Debug Panel ---
# Set to true/1 to enable the in-app debug log panel (Console + Network + Logcat tabs).
# BUILD-TIME: read by babel.config.js (via dotenv) and npm scripts (scripts/with-env.js).
# When false (default for production), all debug panel code is eliminated from the bundle via DCE.
#
# Usage:
#   • Set here, then: npm run start / npm run android (scripts load .env automatically)
#   • Force on: npm run start:debug
#   • After changes: restart Metro (npm run start -- --reset-cache) and rebuild native if needed
SHOW_DEBUG_PANEL=true

# Android logcat filter keywords for debug panel (comma-separated, build-time).
# Read by android/dotenv.gradle (shell env overrides .env).
# Omit or leave empty to show all logcat lines (no keyword filter).
# Example:
#   LOGCAT_FILTER_KEYWORDS=JIGUANG,JPush
# LOGCAT_FILTER_KEYWORDS=JIGUANG

# --- Network Logging ---
# Set to 1 to print full request/response bodies to the console.
MM_MOBILE_LOG_FETCH=1

# --- Dev server ---
CONNECT_URL=https://ai.optibot.cn:8065