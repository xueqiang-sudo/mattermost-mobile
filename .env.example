# Copy this file to .env and adjust values for local development.
# .env is git-ignored and should never be committed.

# --- Debug Panel ---
# Set to true/1 to enable the in-app debug log panel (Console + Network + Logcat tabs).
# This is a BUILD-TIME variable consumed by babel.config.js (not the React Native runtime).
# When false (default for production), all debug panel code is eliminated from the bundle via DCE.
#
# Usage:
#   • Local dev (panel on):  SHOW_DEBUG_PANEL=true npm run start
#   • One-off:               SHOW_DEBUG_PANEL=false npm run android
#   • Or set here and Metro will pick it up on next cold start.
SHOW_DEBUG_PANEL=true

# Android logcat filter keywords for debug panel (comma-separated, build-time).
# Example:
#   LOGCAT_FILTER_KEYWORDS=JIGUANG,JPush
# Set empty to disable filtering and display all logcat lines.
LOGCAT_FILTER_KEYWORDS=JIGUANG

# --- Network Logging ---
# Set to 1 to print full request/response bodies to the console.
MM_MOBILE_LOG_FETCH=1

# --- Dev server ---
CONNECT_URL=https://ai.optibot.cn:8065